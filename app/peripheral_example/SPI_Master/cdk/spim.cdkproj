          <RunUserProg>no</RunUserProg>
          <UserProgName/>
          <IsBatchScript>no</IsBatchScript>
        </BeforeMake>
        <AfterMake>
          <RunUserProg>no</RunUserProg>
          <UserProgName/>
          <IsBatchScript>no</IsBatchScript>
        </AfterMake>
        <Tools/>
      </User>
      <Compiler>
        <Define/>
        <Undefine/>
        <Optim>Optimize size (-Os)</Optim>
        <DebugLevel>Maximum (-g3)</DebugLevel>
        <IncludePath>$(ProjectPath);$(ProjectPath)/..;$(ProjectPath)/../../../../components/ble/v0/utils;$(ProjectPath)/../../../../components/core/riscv/E902;$(ProjectPath)/../../../../components/driver;$(ProjectPath)/../../../../components/header;$(ProjectPath)/../../../../components/libraries;$(ProjectPath)/../../../../components/libraries/24g;$(ProjectPath)/../../../../components/misc;$(ProjectPath)/../../../../modules/hal_clock;$(ProjectPath)/../../../../modules/hal_gpio</IncludePath>
        <OtherFlags>-ffunction-sections -fdata-sections</OtherFlags>
        <Verbose>no</Verbose>
        <Ansi>no</Ansi>
        <Syntax>no</Syntax>
        <Pedantic>no</Pedantic>
        <PedanticErr>no</PedanticErr>
        <InhibitWarn>no</InhibitWarn>
        <AllWarn>yes</AllWarn>
        <WarnErr>no</WarnErr>
        <OneElfS>yes</OneElfS>
        <OneElfSPerData>yes</OneElfSPerData>
        <Fstrict>no</Fstrict>
      </Compiler>
      <Asm>
        <Define/>
        <Undefine/>
        <IncludePath>$(ProjectPath);$(ProjectPath)/..;$(ProjectPath)/../../../../components/ble/v0/utils;$(ProjectPath)/../../../../components/core/riscv/E902;$(ProjectPath)/../../../../components/driver;$(ProjectPath)/../../../../components/header;$(ProjectPath)/../../../../components/libraries;$(ProjectPath)/../../../../components/libraries/24g;$(ProjectPath)/../../../../components/misc;$(ProjectPath)/../../../../modules/hal_adv;$(ProjectPath)/../../../../modules/hal_clock;$(ProjectPath)/../../../../modules/hal_gpio;$(ProjectPath)/../../../../modules/hal_sleep;$(ProjectPath)/../../../../modules/hal_timer</IncludePath>
        <OtherFlags>-ffunction-sections -fdata-sections</OtherFlags>
        <DebugLevel>gdwarf2</DebugLevel>
      </Asm>
